#!/usr/bin/env bash
set -euo pipefail

IMAGE="claude-cask:latest"
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

MODEL="opus"
SAFE_MODE=0
REBUILD=0
EXTRA_ARGS=()

usage() {
  cat <<'EOF'
claude-cask - run Claude Code inside a Docker container

USAGE:
  claude-cask [--model NAME] [--safe] [--rebuild] [-- <args passed to claude>]

OPTIONS:
  --model NAME   Model to use (default: opus)
  --safe         Disable auto mode (omits --permission-mode auto)
  --rebuild      Force-rebuild the claude-cask:latest image before running
  -h, --help     Show this help

The current working directory is mounted at /workspace in the container.
Host ~/.claude is forwarded; one configured GPG signing key is forwarded.

The image is built automatically on first invocation. After editing
Dockerfile or entrypoint.sh, pass --rebuild (or run
"docker build -t claude-cask:latest <repo-dir>") to refresh it.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)   MODEL="$2"; shift 2 ;;
    --safe)    SAFE_MODE=1; shift ;;
    --rebuild) REBUILD=1; shift ;;
    -h|--help) usage; exit 0 ;;
    --)       shift; EXTRA_ARGS+=("$@"); break ;;
    *)        EXTRA_ARGS+=("$1"); shift ;;
  esac
done

command -v docker >/dev/null 2>&1 || { echo "claude-cask: docker not found in PATH" >&2; exit 1; }

GIT_NAME="$(git config --global --get user.name  || true)"
GIT_EMAIL="$(git config --global --get user.email || true)"
SIGNING_KEY="$(git config --global --get user.signingkey || true)"
GPG_SIGN="$(git config --global --get commit.gpgsign || echo false)"

[[ -n "$GIT_NAME"  ]] || { echo "claude-cask: git user.name not set on host"  >&2; exit 1; }
[[ -n "$GIT_EMAIL" ]] || { echo "claude-cask: git user.email not set on host" >&2; exit 1; }

if [[ $REBUILD -eq 1 ]] || ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  docker build -t "$IMAGE" "$SCRIPT_DIR"
fi

GPG_MOUNTS=()
GPG_ENV=()
TMP_KEY_DIR=""
STAGED_CREDS_FILE=""

# shellcheck disable=SC2329  # invoked via trap
cleanup() {
  if [[ -n "$TMP_KEY_DIR" && -d "$TMP_KEY_DIR" ]]; then
    rm -rf "$TMP_KEY_DIR"
  fi
  if [[ -n "$STAGED_CREDS_FILE" && -f "$STAGED_CREDS_FILE" ]]; then
    rm -f "$STAGED_CREDS_FILE"
  fi
  return 0
}
trap cleanup EXIT

if [[ -n "$SIGNING_KEY" ]]; then
  TMP_KEY_DIR="$(mktemp -d)"
  KEY_FILE="$TMP_KEY_DIR/signing-key.asc"
  if ! gpg --export --armor "$SIGNING_KEY" > "$KEY_FILE" || [[ ! -s "$KEY_FILE" ]]; then
    echo "claude-cask: failed to export signing key $SIGNING_KEY" >&2
    exit 1
  fi

  AGENT_SOCKET="$(gpgconf --list-dirs agent-extra-socket)"
  if [[ ! -S "$AGENT_SOCKET" ]]; then
    echo "claude-cask: gpg-agent extra socket not found at $AGENT_SOCKET (is gpg-agent running?)" >&2
    exit 1
  fi

  GPG_MOUNTS+=(
    -v "$KEY_FILE:/tmp/signing-key.asc:ro"
    -v "$AGENT_SOCKET:/root/.gnupg/S.gpg-agent"
  )
  GPG_ENV+=(
    -e "CLAUDE_CASK_SIGNING_KEY=$SIGNING_KEY"
    -e "CLAUDE_CASK_GPG_SIGN=$GPG_SIGN"
  )
fi

CLAUDE_ARGS=(--model "$MODEL")
[[ $SAFE_MODE -eq 0 ]] && CLAUDE_ARGS+=(--permission-mode auto)
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
  CLAUDE_ARGS+=("${EXTRA_ARGS[@]}")
fi

DOCKER_ARGS=(run --rm -it
  -v "$PWD:/workspace"
  -v "$HOME/.claude:/root/.claude"
  -e "GIT_AUTHOR_NAME=$GIT_NAME"
  -e "GIT_AUTHOR_EMAIL=$GIT_EMAIL"
  -e "GIT_COMMITTER_NAME=$GIT_NAME"
  -e "GIT_COMMITTER_EMAIL=$GIT_EMAIL"
)
# Mount the host's primary Claude Code config file (theme etc) when present.
if [[ -f "$HOME/.claude.json" ]]; then
  DOCKER_ARGS+=(-v "$HOME/.claude.json:/root/.claude.json")
fi

# On macOS, Claude Code stores its OAuth token in the Keychain rather than
# in any file. The Linux Claude Code inside the container reads its token
# from ~/.claude/.credentials.json. We can't bind-mount the credentials file
# at /root/.claude/.credentials.json because Docker Desktop's virtiofs cannot
# stack a file mount inside a directory bind-mount. Instead, write the
# credentials directly to the host's $HOME/.claude/.credentials.json (which
# is then visible inside the container via the existing dir mount), and
# remove it from the host on exit. The keychain still holds the canonical
# token; this is just a brief on-disk mirror with the same mode (600).
if [[ "$(uname -s)" == "Darwin" ]] && command -v security >/dev/null 2>&1; then
  if creds_json="$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null)" \
       && [[ -n "$creds_json" ]]; then
    HOST_CREDS_FILE="$HOME/.claude/.credentials.json"
    # A zero-byte file is a stale leftover (e.g., a previous failed bind-mount
    # left an empty mountpoint behind). Remove it so we can stage fresh creds.
    if [[ -e "$HOST_CREDS_FILE" && ! -s "$HOST_CREDS_FILE" ]]; then
      rm -f "$HOST_CREDS_FILE"
    fi
    if [[ -e "$HOST_CREDS_FILE" ]]; then
      echo "claude-cask: $HOST_CREDS_FILE already exists on host; not overwriting. The in-container Claude will use it as-is." >&2
    else
      mkdir -p "$HOME/.claude"
      umask_old="$(umask)"
      umask 077
      printf '%s' "$creds_json" > "$HOST_CREDS_FILE"
      umask "$umask_old"
      STAGED_CREDS_FILE="$HOST_CREDS_FILE"
    fi
  fi
fi
if [[ ${#GPG_ENV[@]} -gt 0 ]]; then
  DOCKER_ARGS+=("${GPG_ENV[@]}")
fi
if [[ ${#GPG_MOUNTS[@]} -gt 0 ]]; then
  DOCKER_ARGS+=("${GPG_MOUNTS[@]}")
fi
DOCKER_ARGS+=("$IMAGE" "${CLAUDE_ARGS[@]}")

# Don't `exec` — we need the cleanup trap to run after docker exits so we
# remove the staged ~/.claude/.credentials.json from the host.
docker "${DOCKER_ARGS[@]}"
exit $?
