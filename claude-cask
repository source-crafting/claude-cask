#!/usr/bin/env bash
set -euo pipefail

IMAGE="claude-cask:latest"

# Resolve the script path through any symlinks before deriving SCRIPT_DIR.
# README recommends installing via `ln -s` into /usr/local/bin/, so without
# this the docker-build context (--rebuild and first-run auto-build) would
# point at the symlink directory and fail. BSD readlink lacks -f, so do it
# manually for portability across macOS and Linux.
__cc_resolve_symlink() {
  local target="$1"
  local hops=0
  while [[ -L "$target" ]]; do
    if (( hops >= 40 )); then
      echo "claude-cask: too many symlink hops resolving $1 (cycle?)" >&2
      exit 1
    fi
    local link
    link="$(readlink "$target")"
    if [[ "$link" = /* ]]; then
      target="$link"
    else
      target="$(dirname "$target")/$link"
    fi
    ((hops++))
  done
  printf '%s' "$target"
}
SCRIPT_DIR="$( cd "$( dirname "$(__cc_resolve_symlink "${BASH_SOURCE[0]}")" )" && pwd )"

MODEL="opus"
AUTO_MODE=0
REBUILD=0
EXPLICIT_REBUILD=0
UPDATE_CC=0
KEEP_CONTAINER=0
EXTRA_ARGS=()
BARE=0

usage() {
  cat <<'EOF'
claude-cask - run Claude Code inside a Docker container

USAGE:
  claude-cask [--model NAME] [--auto] [--rebuild]
              [--keep-container] [-- <args passed to claude>]
  claude-cask install --apt|--npm|--pip|--cargo PKG [PKG...]
  claude-cask remove  --apt|--npm|--pip|--cargo PKG [PKG...]
  claude-cask list

OPTIONS:
  --model NAME      Model to use (default: opus)
  --auto            Enable auto mode (--permission-mode auto). Off by default;
                    use this only when you trust the AI to run tool calls
                    without per-action confirmation.
  --rebuild         Force-rebuild claude-cask:latest (and claude-cask:user
                    if any user-extras manifest is non-empty), then exit.
                    Does NOT launch the Claude Code TUI.
  --update-claude-code
                    Resolve the latest claude-code on npm, rebuild
                    claude-cask:latest with that version (busting the
                    install layer cache), then rebuild claude-cask:user
                    if any user-extras manifest is non-empty. Exits
                    without launching the Claude Code TUI.
  --keep-container  Don't pass --rm to docker run. The container survives
                    after exit, so `docker logs <id>` and `docker inspect
                    <id>` are available for post-mortem debugging. The
                    launcher prints the container id and cleanup hints at
                    exit. You're responsible for `docker rm` when done.
  --bare            Launch with claude-cask:latest even when user-extras
                    manifests are populated (skips claude-cask:user).
  -h, --help        Show this help

USER-EXTRAS SUBCOMMANDS:
  install --<eco> PKG [PKG...]
                    Add one or more packages to the <eco> manifest and
                    rebuild claude-cask:user on top of :latest. Manifests
                    persist under ~/.config/claude-cask/<eco>.list and
                    are layered into the container at launch.
  remove  --<eco> PKG [PKG...]
                    Remove the named packages from the <eco> manifest and
                    rebuild claude-cask:user. If all manifests become
                    empty, claude-cask:user is untagged.
  list              Print the current contents of every manifest, grouped
                    by ecosystem. Exits non-zero only on an internal error.

  Ecosystem flags: --apt | --npm | --pip | --cargo

The current working directory is mounted at the same path inside the container.
Host ~/.claude is forwarded; one configured GPG signing key is forwarded.

The image is built automatically on first invocation. After editing
Dockerfile or entrypoint.sh, pass --rebuild (or run
"docker build -t claude-cask:latest <repo-dir>") to refresh it.
EOF
}

# --- Subcommand dispatch (extras) --------------------------------------------
# install/remove/list are standalone actions: they perform their work and
# exit without launching the Claude TUI. Detected by the FIRST positional
# token only; `claude-cask -- install` still passes the literal word
# through to claude.
EXTRAS_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claude-cask"

extras_list() {
  local any=0 eco
  for eco in apt npm pip cargo; do
    local f="$EXTRAS_DIR/${eco}.list"
    if [[ -s "$f" ]]; then
      any=1
      echo "[$eco]"
      grep -v '^#' "$f" | grep -v '^[[:space:]]*$' || true
      echo
    fi
  done
  if [[ $any -eq 0 ]]; then
    echo "(no extras configured)"
  fi
}

manifest_path() { echo "$EXTRAS_DIR/${1}.list"; }

manifest_read() {
  local f; f="$(manifest_path "$1")"
  [[ -f "$f" ]] || return 0
  grep -Ev '^([[:space:]]*$|#)' "$f" || true
}

manifest_write_sorted() {
  local eco="$1"; shift
  mkdir -p "$EXTRAS_DIR"
  local f; f="$(manifest_path "$eco")"
  local tmp="${f}.tmp.$$"
  if [[ $# -eq 0 ]]; then
    : > "$tmp"
  else
    printf '%s\n' "$@" | sort -u > "$tmp"
  fi
  mv "$tmp" "$f"
}

# Sort the args alphabetically and emit "a, b, c". Used by manifest_add /
# manifest_remove for their `added: ...` / `removed: ...` summary lines.
_join_sorted() {
  local first=1 item
  while IFS= read -r item; do
    if (( first )); then printf '%s' "$item"; first=0
    else                 printf ', %s' "$item"
    fi
  done < <(printf '%s\n' "$@" | sort)
}

manifest_add() {
  local eco="$1"; shift
  local existing=() added=() already=()
  mapfile -t existing < <(manifest_read "$eco")
  local pkg
  for pkg in "$@"; do
    local found=0 e
    for e in "${existing[@]+"${existing[@]}"}"; do
      [[ "$e" == "$pkg" ]] && { found=1; break; }
    done
    if [[ $found -eq 1 ]]; then
      already+=("$pkg")
    else
      added+=("$pkg")
      existing+=("$pkg")
    fi
  done
  manifest_write_sorted "$eco" "${existing[@]+"${existing[@]}"}"
  [[ ${#added[@]}   -gt 0 ]] && echo "added: $(_join_sorted "${added[@]}")"
  [[ ${#already[@]} -gt 0 ]] && echo "already: $(_join_sorted "${already[@]}")"
  [[ ${#added[@]}   -gt 0 ]]
}

manifest_remove() {
  local eco="$1"; shift
  local existing=() removed=() not_present=()
  mapfile -t existing < <(manifest_read "$eco")
  local pkg
  for pkg in "$@"; do
    local found=0 e
    for e in "${existing[@]+"${existing[@]}"}"; do
      [[ "$e" == "$pkg" ]] && { found=1; break; }
    done
    if [[ $found -eq 1 ]]; then
      removed+=("$pkg")
    else
      not_present+=("$pkg")
    fi
  done
  local keep=() e
  for e in "${existing[@]+"${existing[@]}"}"; do
    local drop=0 r
    for r in "${removed[@]+"${removed[@]}"}"; do
      [[ "$e" == "$r" ]] && { drop=1; break; }
    done
    [[ $drop -eq 0 ]] && keep+=("$e")
  done
  manifest_write_sorted "$eco" "${keep[@]+"${keep[@]}"}"
  [[ ${#removed[@]}     -gt 0 ]] && echo "removed: $(_join_sorted "${removed[@]}")"
  [[ ${#not_present[@]} -gt 0 ]] && echo "not_present: $(_join_sorted "${not_present[@]}")"
  [[ ${#removed[@]}     -gt 0 ]]
}

manifests_all_empty() {
  local eco
  for eco in apt npm pip cargo; do
    [[ -n "$(manifest_read "$eco")" ]] && return 1
  done
  return 0
}

manifest_snapshot() {
  # Echoes a snapshot blob that manifest_restore can consume.
  local eco f
  for eco in apt npm pip cargo; do
    f="$(manifest_path "$eco")"
    if [[ -f "$f" ]]; then
      echo "==FILE==$eco"
      cat "$f"
      echo "==END=="
    else
      echo "==ABSENT==$eco"
    fi
  done
}

manifest_restore() {
  # Reads the blob from stdin and rewrites all four manifests.
  mkdir -p "$EXTRAS_DIR"
  local line eco buf=""
  local mode=""
  while IFS= read -r line; do
    case "$line" in
      "==FILE=="*)   eco="${line#==FILE==}"; mode=file; buf="" ;;
      "==ABSENT=="*) eco="${line#==ABSENT==}"; rm -f "$(manifest_path "$eco")"; mode="" ;;
      "==END==")     printf '%s' "$buf" > "$(manifest_path "$eco")"; mode="" ;;
      *)             [[ "$mode" == file ]] && buf+="$line"$'\n' ;;
    esac
  done
}

parse_eco_flag() {
  # On success, sets global ECO from --apt/--npm/--pip/--cargo.
  # The CALLER is responsible for the matching shift after success.
  case "${1:-}" in
    --apt|--npm|--pip|--cargo) ECO="${1#--}"; return 0 ;;
    *) echo "claude-cask: install/remove require an ecosystem flag (--apt|--npm|--pip|--cargo)" >&2; return 2 ;;
  esac
}

EXTRAS_LOCK_HELD=0

release_extras_lock() {
  if [[ "$EXTRAS_LOCK_HELD" -eq 1 ]]; then
    rm -rf "$EXTRAS_DIR/.lock" 2>/dev/null || true
    EXTRAS_LOCK_HELD=0
  fi
}

acquire_extras_lock() {
  # mkdir is atomic on POSIX, so we use a lock *directory* instead of
  # `flock` (util-linux only — not present on macOS by default). The lock
  # is released either by `release_extras_lock` via the EXIT trap below,
  # or by `cleanup` for code paths that override the trap later. A PID
  # file inside the dir lets us reclaim the lock when its previous holder
  # crashed (kill -9, host reboot mid-build) without manual intervention.
  mkdir -p "$EXTRAS_DIR"
  # Drop any leftover regular file from the older flock-based launcher.
  # Guard with `-f` because `rm -f` on a directory still errors (EISDIR);
  # a real lock dir from a concurrent or crashed run is handled below.
  [[ -f "$EXTRAS_DIR/.lock" ]] && rm -f "$EXTRAS_DIR/.lock"
  while ! mkdir "$EXTRAS_DIR/.lock" 2>/dev/null; do
    local holder=""
    [[ -f "$EXTRAS_DIR/.lock/pid" ]] && holder="$(cat "$EXTRAS_DIR/.lock/pid" 2>/dev/null || true)"
    if [[ -n "$holder" ]] && kill -0 "$holder" 2>/dev/null; then
      echo "claude-cask: another install/remove/rebuild is in progress (pid $holder)" >&2
      exit 1
    fi
    echo "claude-cask: removing stale lock (holder pid ${holder:-?} no longer running)" >&2
    rm -rf "$EXTRAS_DIR/.lock"
  done
  echo "$$" > "$EXTRAS_DIR/.lock/pid"
  EXTRAS_LOCK_HELD=1
  trap release_extras_lock EXIT
}

build_user_image() {
  # Reads the rendered Dockerfile on stdin. Returns docker's exit code.
  render_user_dockerfile | docker build -t claude-cask:user -
}

extras_install() {
  parse_eco_flag "$@" || exit $?
  shift
  if [[ $# -eq 0 ]]; then
    echo "claude-cask: install --$ECO requires at least one package" >&2
    exit 2
  fi
  acquire_extras_lock
  local snap; snap="$(manifest_snapshot)"
  if ! manifest_add "$ECO" "$@"; then
    # All duplicates — nothing changed, no rebuild needed.
    return 0
  fi
  if ! build_user_image; then
    echo "claude-cask: docker build failed; rolling back $ECO manifest" >&2
    printf '%s' "$snap" | manifest_restore
    exit 1
  fi
  echo "claude-cask: $ECO manifest updated; claude-cask:user rebuilt"
}

extras_remove() {
  parse_eco_flag "$@" || exit $?
  shift
  if [[ $# -eq 0 ]]; then
    echo "claude-cask: remove --$ECO requires at least one package" >&2
    exit 2
  fi
  acquire_extras_lock
  local snap; snap="$(manifest_snapshot)"
  if ! manifest_remove "$ECO" "$@"; then
    # Nothing was actually present — exit 0, no rebuild.
    return 0
  fi
  if manifests_all_empty; then
    if ! docker image inspect claude-cask:user >/dev/null 2>&1; then
      echo "claude-cask: all manifests empty; claude-cask:user already absent"
    elif docker rmi claude-cask:user >/dev/null 2>&1; then
      echo "claude-cask: all manifests empty; claude-cask:user untagged"
    else
      echo "claude-cask: all manifests empty, but claude-cask:user removal failed (in use?)" >&2
      exit 1
    fi
    return 0
  fi
  if ! build_user_image; then
    echo "claude-cask: docker build failed; rolling back $ECO manifest" >&2
    printf '%s' "$snap" | manifest_restore
    exit 1
  fi
  echo "claude-cask: $ECO manifest updated; claude-cask:user rebuilt"
}

render_user_dockerfile() {
  # Flatten newline-separated manifest lines into space-separated tokens
  # so they slot into the apt/npm/pip/cargo command lines below. apt, npm,
  # pip and cargo package names cannot contain whitespace, so this is a
  # safe shape change — not just a convenience.
  local apt_pkgs npm_pkgs pip_pkgs cargo_pkgs
  apt_pkgs="$(manifest_read apt | tr '\n' ' ')"
  npm_pkgs="$(manifest_read npm | tr '\n' ' ')"
  pip_pkgs="$(manifest_read pip | tr '\n' ' ')"
  cargo_pkgs="$(manifest_read cargo | tr '\n' ' ')"

  echo "FROM claude-cask:latest"
  echo "USER root"

  # Compose the apt RUN: user-listed apt packages, plus pipx if pip is
  # non-empty, plus the cargo toolchain + build deps if cargo is non-empty.
  local apt_line="$apt_pkgs"
  if [[ -n "$pip_pkgs" ]]; then
    apt_line+=" pipx"
  fi
  if [[ -n "$cargo_pkgs" ]]; then
    apt_line+=" cargo build-essential pkg-config libssl-dev"
  fi
  apt_line="$(echo "$apt_line" | xargs || true)"  # collapse whitespace
  if [[ -n "$apt_line" ]]; then
    echo "RUN apt-get update && apt-get install -y --no-install-recommends $apt_line && rm -rf /var/lib/apt/lists/*"
  fi

  if [[ -n "$npm_pkgs" ]]; then
    echo "RUN npm install -g $(echo "$npm_pkgs" | xargs)"
  fi

  if [[ -n "$pip_pkgs" ]]; then
    # pipx --global requires pipx >= 1.4. Debian-stable's pipx may be older;
    # in that case the binaries land in /root/.local/bin and we symlink them
    # into /usr/local/bin so the runtime user finds them on PATH.
    local p
    for p in $pip_pkgs; do
      echo "RUN pipx install --global \"$p\" 2>/dev/null || (pipx install \"$p\" && ln -sf /root/.local/bin/* /usr/local/bin/)"
    done
  fi

  if [[ -n "$cargo_pkgs" ]]; then
    local c
    for c in $cargo_pkgs; do
      echo "RUN cargo install --root /usr/local \"$c\""
    done
  fi

  # Do NOT add `USER claude-cask` here: the entrypoint needs to start as
  # root to set up the gpg-agent bridge before dropping privileges via
  # gosu. Setting USER skips the root section and signing breaks silently.
  echo "LABEL claude-cask.user-hash=\"$(user_hash)\""
}

# Hash inputs that determine staleness of :user: the four manifests
# plus the base image's content ID. If any drifts, :user is rebuilt.
user_hash() {
  local base_id
  base_id="$(docker image inspect --format '{{.Id}}' claude-cask:latest 2>/dev/null || echo none)"
  {
    manifest_read apt
    echo "---"
    manifest_read npm
    echo "---"
    manifest_read pip
    echo "---"
    manifest_read cargo
    echo "---"
    echo "$base_id"
  } | shasum -a 256 | cut -d' ' -f1
}

if [[ "${CLAUDE_CASK_SOURCE_ONLY:-0}" == "1" ]]; then
  return 0 2>/dev/null || exit 0
fi

if [[ $# -gt 0 ]]; then
  case "$1" in
    list)
      shift
      [[ $# -eq 0 ]] || { echo "claude-cask: 'list' takes no arguments" >&2; exit 2; }
      extras_list
      exit 0
      ;;
    install)
      shift
      extras_install "$@"
      exit $?
      ;;
    remove)
      shift
      extras_remove "$@"
      exit $?
      ;;
  esac
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model)           MODEL="$2"; shift 2 ;;
    --auto)            AUTO_MODE=1; shift ;;
    --rebuild)         REBUILD=1; EXPLICIT_REBUILD=1; shift ;;
    --update-claude-code) UPDATE_CC=1; shift ;;
    --keep-container)  KEEP_CONTAINER=1; shift ;;
    --bare)            BARE=1; shift ;;
    -h|--help)         usage; exit 0 ;;
    --)                shift; EXTRA_ARGS+=("$@"); break ;;
    -*)                echo "claude-cask: unknown flag '$1' (use -- to pass flags through to claude)" >&2; exit 2 ;;
    *)                 EXTRA_ARGS+=("$1"); shift ;;
  esac
done

command -v docker >/dev/null 2>&1 || { echo "claude-cask: docker not found in PATH" >&2; exit 1; }

# The container runs as a non-root user whose UID/GID match the host user
# so bind-mounted files are owned correctly inside the container. We refuse
# to run as root because (a) creating a UID-0 user inside the container is
# nonsensical and (b) the threat model assumes a regular user account.
HOST_UID="$(id -u)"
HOST_GID="$(id -g)"
[[ "$HOST_UID" -eq 0 ]] && { echo "claude-cask: refusing to run as root (UID 0)" >&2; exit 1; }

# All four reads follow git's normal precedence: local repo config wins
# over global. The pre-flight summary surfaces the resolved signing key
# before the container starts, so per-repo overrides remain auditable.
GIT_NAME="$(git config --get user.name  || true)"
GIT_EMAIL="$(git config --get user.email || true)"
SIGNING_KEY="$(git config --get user.signingkey || true)"
GPG_SIGN="$(git config --get commit.gpgsign || echo false)"

[[ -n "$GIT_NAME"  ]] || { echo "claude-cask: git user.name not set on host"  >&2; exit 1; }
[[ -n "$GIT_EMAIL" ]] || { echo "claude-cask: git user.email not set on host" >&2; exit 1; }

# Hash the contents of the build context (per .dockerignore: Dockerfile +
# entrypoint.sh). If the hash recorded in the existing image's label
# doesn't match what's on disk now, the image is stale and we rebuild.
SRC_HASH="$(cat "$SCRIPT_DIR/Dockerfile" "$SCRIPT_DIR/entrypoint.sh" | shasum -a 256 | cut -d' ' -f1)"

if [[ "${UPDATE_CC:-0}" -eq 1 ]]; then
  command -v npm >/dev/null 2>&1 || { echo "claude-cask: --update-claude-code requires npm on host PATH" >&2; exit 1; }
  cc_version="$(npm view @anthropic-ai/claude-code version)"
  [[ -n "$cc_version" ]] || { echo "claude-cask: failed to resolve claude-code version via npm view" >&2; exit 1; }
  acquire_extras_lock
  docker build \
    --build-arg "USER_UID=$HOST_UID" \
    --build-arg "USER_GID=$HOST_GID" \
    --build-arg "IMAGE_HASH=$SRC_HASH" \
    --build-arg "CLAUDE_CODE_VERSION=$cc_version" \
    -t "$IMAGE" "$SCRIPT_DIR"
  if ! manifests_all_empty; then
    if ! build_user_image; then
      echo "claude-cask: docker build failed for claude-cask:user" >&2
      exit 1
    fi
  fi
  echo "claude-cask: claude-code updated to $cc_version"
  exit 0
fi

# Auto-rebuild when the existing image is stale relative to the host:
# either the user/group don't match (UID drift after switching machines)
# or the Dockerfile/entrypoint have been edited since the last build.
if [[ $REBUILD -eq 0 ]] && docker image inspect "$IMAGE" >/dev/null 2>&1; then
  image_uid="$(docker image inspect --format '{{ index .Config.Labels "claude-cask.uid" }}' "$IMAGE" 2>/dev/null || true)"
  image_gid="$(docker image inspect --format '{{ index .Config.Labels "claude-cask.gid" }}' "$IMAGE" 2>/dev/null || true)"
  image_hash="$(docker image inspect --format '{{ index .Config.Labels "claude-cask.image-hash" }}' "$IMAGE" 2>/dev/null || true)"
  if [[ "$image_uid" != "$HOST_UID" || "$image_gid" != "$HOST_GID" ]]; then
    echo "claude-cask: image was built for UID/GID ${image_uid:-?}:${image_gid:-?}, host is $HOST_UID:$HOST_GID — rebuilding" >&2
    REBUILD=1
  elif [[ "$image_hash" != "$SRC_HASH" ]]; then
    echo "claude-cask: Dockerfile or entrypoint.sh changed since last build — rebuilding" >&2
    REBUILD=1
  fi
fi

# When the user explicitly asked --rebuild, serialize against concurrent
# install/remove/--rebuild so we don't redundantly rebuild :latest twice.
if [[ "${EXPLICIT_REBUILD:-0}" -eq 1 ]]; then
  acquire_extras_lock
fi

if [[ $REBUILD -eq 1 ]] || ! docker image inspect "$IMAGE" >/dev/null 2>&1; then
  docker build \
    --build-arg "USER_UID=$HOST_UID" \
    --build-arg "USER_GID=$HOST_GID" \
    --build-arg "IMAGE_HASH=$SRC_HASH" \
    -t "$IMAGE" "$SCRIPT_DIR"
  # Reclaim the previous claude-cask image, now dangling because the new
  # build replaced its :latest tag. Scoped to our label so other dangling
  # images on the host (from unrelated Docker work) are left alone.
  docker image prune -f --filter "label=claude-cask.uid" >/dev/null 2>&1 || true
fi

if [[ "${EXPLICIT_REBUILD:-0}" -eq 1 ]]; then
  if ! manifests_all_empty; then
    if ! build_user_image; then
      echo "claude-cask: docker build failed for claude-cask:user" >&2
      exit 1
    fi
    echo "claude-cask: rebuilt claude-cask:latest and claude-cask:user"
  else
    echo "claude-cask: rebuilt claude-cask:latest"
  fi
  exit 0
fi

# --- :user image selection -------------------------------------------------
# If any manifest is non-empty, run with :user. Rebuild if its label hash
# is stale (manifests changed, or :latest was rebuilt under us).
if ! manifests_all_empty && [[ "${BARE:-0}" -eq 0 ]]; then
  want_hash="$(user_hash)"
  user_label="$(docker image inspect --format '{{ index .Config.Labels "claude-cask.user-hash" }}' claude-cask:user 2>/dev/null || true)"
  if [[ "$user_label" != "$want_hash" ]]; then
    echo "claude-cask: :user image stale or missing — rebuilding" >&2
    if ! build_user_image; then
      echo "claude-cask: docker build failed for claude-cask:user" >&2
      exit 1
    fi
  fi
  IMAGE="claude-cask:user"
fi

GPG_MOUNTS=()
GPG_ENV=()
TMP_KEY_DIR=""

# shellcheck disable=SC2329  # invoked via trap
cleanup() {
  if [[ -n "$TMP_KEY_DIR" && -d "$TMP_KEY_DIR" ]]; then
    rm -rf "$TMP_KEY_DIR"
  fi
  release_extras_lock
  return 0
}
trap cleanup EXIT

if [[ -n "$SIGNING_KEY" ]]; then
  TMP_KEY_DIR="$(mktemp -d)"
  KEY_FILE="$TMP_KEY_DIR/signing-key.asc"
  # The "!" suffix tells gpg to match this key exactly (no fuzzy short-ID
  # collisions). Without it, a short-ID like "62EEA734" could match more
  # than one key in the host keyring and we'd export all of them.
  if ! gpg --export --armor --export-options export-minimal "${SIGNING_KEY}!" > "$KEY_FILE" \
       || [[ ! -s "$KEY_FILE" ]]; then
    echo "claude-cask: failed to export signing key $SIGNING_KEY" >&2
    exit 1
  fi

  AGENT_SOCKET="$(gpgconf --list-dirs agent-extra-socket)"
  if [[ ! -S "$AGENT_SOCKET" ]]; then
    echo "claude-cask: gpg-agent extra socket not found at $AGENT_SOCKET (is gpg-agent running?)" >&2
    exit 1
  fi

  GPG_MOUNTS+=(
    -v "$KEY_FILE:/tmp/signing-key.asc:ro"
    -v "$AGENT_SOCKET:/run/host-gpg-agent"
  )
  GPG_ENV+=(
    -e "CLAUDE_CASK_SIGNING_KEY=$SIGNING_KEY"
    -e "CLAUDE_CASK_GPG_SIGN=$GPG_SIGN"
  )
fi

CLAUDE_ARGS=(--model "$MODEL")
# Always pass --permission-mode explicitly so the launcher's choice wins
# over any defaultMode set in the user's host ~/.claude/settings.json
# (which is mounted into the container and would otherwise take effect).
if [[ $AUTO_MODE -eq 1 ]]; then
  CLAUDE_ARGS+=(--permission-mode auto)
else
  CLAUDE_ARGS+=(--permission-mode default)
fi
if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
  CLAUDE_ARGS+=("${EXTRA_ARGS[@]}")
fi

# Default: --rm so the container is ephemeral. With --keep-container the
# container is preserved after exit so docker logs/inspect work for
# post-mortem; the launcher records the container id via --cidfile and
# prints cleanup hints on exit.
CID_FILE=""
DOCKER_ARGS=(run -it)
if [[ $KEEP_CONTAINER -eq 0 ]]; then
  DOCKER_ARGS+=(--rm)
else
  CID_FILE="$(mktemp)"
  rm -f "$CID_FILE"   # docker --cidfile refuses to overwrite an existing file
  DOCKER_ARGS+=(--cidfile "$CID_FILE")
fi
DOCKER_ARGS+=(
  # Mount $PWD at the same path inside the container (rather than at a
  # generic /workspace). Claude Code keys per-project session history off
  # the cwd; mirroring the host path means projectA at /Users/x/A and
  # projectB at /Users/x/B get distinct keys, and they line up with what
  # host `claude` would record for the same paths.
  -v "$PWD:$PWD"
  -w "$PWD"
  -e "CLAUDE_CASK_WORKDIR=$PWD"
  -v "$HOME/.claude:/home/claude-cask/.claude"
  # Forward the host home path so the entrypoint can symlink it to
  # /home/claude-cask. Plugin metadata under ~/.claude (installPath,
  # installLocation) records absolute host paths; the symlink makes
  # those paths resolve inside the container so skills load.
  -e "HOST_HOME=$HOME"
  -e "GIT_AUTHOR_NAME=$GIT_NAME"
  -e "GIT_AUTHOR_EMAIL=$GIT_EMAIL"
  -e "GIT_COMMITTER_NAME=$GIT_NAME"
  -e "GIT_COMMITTER_EMAIL=$GIT_EMAIL"
)

# Forward terminal-identification env vars so Claude Code's keybindings
# (e.g., Shift/Ctrl+Enter for newline) match the host terminal. Only
# forwarded when set on the host; unset values are skipped.
for v in TERM_PROGRAM TERM_PROGRAM_VERSION COLORTERM; do
  if [[ -n "${!v:-}" ]]; then
    DOCKER_ARGS+=(-e "$v=${!v}")
  fi
done
# Mount the host's primary Claude Code config file (theme etc) when present.
if [[ -f "$HOME/.claude.json" ]]; then
  DOCKER_ARGS+=(-v "$HOME/.claude.json:/home/claude-cask/.claude.json")
fi

# Note on the threat model: ~/.claude is mounted RW so Claude inside the
# container can manage its own state — install/uninstall plugins, refresh
# marketplaces, update enabledPlugins in settings.json, write sessions, etc.
# That means an in-container AI *could*, in principle, plant code that a
# subsequent host claude session would execute (e.g., a malicious skill in
# plugins/cache/, or a "hooks" entry in settings.json that runs arbitrary
# shell on session events). claude-cask trusts the in-container AI not to
# do that — same trust you're already placing in it for everything else
# inside the container's bounds. If you want stricter isolation, layer
# read-only mounts over plugins/cache/ and settings.json yourself; expect
# plugin install/uninstall and marketplace refresh to break inside the
# container if you do, since both write to those paths.

# On macOS, Claude Code stores its OAuth token in the Keychain rather than
# in any file. The Linux Claude Code inside the container reads it from
# ~/.claude/.credentials.json. The launcher writes that file from the
# keychain only when it doesn't already exist on the host, then leaves it
# alone for the rest of its life — claude-cask is a *consumer* of the
# credentials store, not its owner. Deleting on exit would break any other
# claude session reading the same file (host claude on Linux, another
# container, even host claude on macOS if it's been written here).
#
# The file persists on disk indefinitely. With FileVault on (default on
# modern Macs) and an encrypted Time Machine destination, this is roughly
# equivalent in security to the keychain itself. See SECURITY.md.
if [[ "$(uname -s)" == "Darwin" ]] && command -v security >/dev/null 2>&1; then
  HOST_CREDS_FILE="$HOME/.claude/.credentials.json"
  if [[ ! -e "$HOST_CREDS_FILE" ]]; then
    if creds_json="$(security find-generic-password -s "Claude Code-credentials" -a "$USER" -w 2>/dev/null)" \
         && [[ -n "$creds_json" ]]; then
      mkdir -p "$HOME/.claude"
      chmod 700 "$HOME/.claude"
      umask_old="$(umask)"
      umask 077
      printf '%s' "$creds_json" > "$HOST_CREDS_FILE"
      umask "$umask_old"
    fi
  fi
fi
if [[ ${#GPG_ENV[@]} -gt 0 ]]; then
  DOCKER_ARGS+=("${GPG_ENV[@]}")
fi
if [[ ${#GPG_MOUNTS[@]} -gt 0 ]]; then
  DOCKER_ARGS+=("${GPG_MOUNTS[@]}")
fi
DOCKER_ARGS+=("$IMAGE" "${CLAUDE_ARGS[@]}")

# --- Pre-flight summary -------------------------------------------------------
# Print what's about to be mounted/forwarded and (when stdin is a tty) ask
# for confirmation. Catches "wrong directory" mistakes — the workspace mount
# is the bound on the AI's filesystem reach, so naming it explicitly is the
# cheapest possible safety check. Skipped when stdin is not a tty so scripted
# invocations aren't blocked.
{
  echo "claude-cask:"
  echo "  workspace:    $PWD"
  echo "  ~/.claude:    $HOME/.claude  (rw)"
  if [[ -f "$HOME/.claude.json" ]]; then
    echo "  ~/.claude.json: $HOME/.claude.json  (rw)"
  fi
  if [[ -n "$SIGNING_KEY" ]]; then
    echo "  signing:      $SIGNING_KEY  (via gpg-agent bridge)"
  else
    echo "  signing:      disabled (no host user.signingkey)"
  fi
  echo "  network:      open (full outbound)"
  apt_n=$(manifest_read apt | wc -l | tr -d ' ')
  npm_n=$(manifest_read npm | wc -l | tr -d ' ')
  pip_n=$(manifest_read pip | wc -l | tr -d ' ')
  cargo_n=$(manifest_read cargo | wc -l | tr -d ' ')
  parts=()
  [[ $apt_n   -gt 0 ]] && parts+=("$apt_n apt")
  [[ $npm_n   -gt 0 ]] && parts+=("$npm_n npm")
  [[ $pip_n   -gt 0 ]] && parts+=("$pip_n pip")
  [[ $cargo_n -gt 0 ]] && parts+=("$cargo_n cargo")
  if [[ ${#parts[@]} -eq 0 ]]; then
    echo "  extras:       none  ($IMAGE)"
  elif [[ "${BARE:-0}" -eq 1 ]]; then
    joined="$(printf '%s, ' "${parts[@]}")"
    joined="${joined%, }"
    echo "  extras:       skipped (--bare) — $joined in manifest"
  else
    joined="$(printf '%s, ' "${parts[@]}")"
    joined="${joined%, }"
    echo "  extras:       $joined  ($IMAGE)"
  fi
  # Surface FileVault state on macOS — SECURITY.md treats "FileVault on" as
  # the assumption that makes a persistent credentials file at rest roughly
  # equivalent to the keychain. If it's off, the user should know.
  if [[ "$(uname -s)" == "Darwin" ]] && command -v fdesetup >/dev/null 2>&1; then
    fv_status="$(fdesetup status 2>/dev/null || true)"
    if [[ "$fv_status" == *"FileVault is On"* ]]; then
      echo "  filevault:    on"
    else
      echo "  filevault:    OFF — host disk is unencrypted; ~/.claude/.credentials.json is plaintext at rest. See SECURITY.md."
    fi
  fi
  if [[ $AUTO_MODE -eq 1 ]]; then
    echo "  mode:         auto — Claude runs tool calls without confirmation"
  else
    echo "  mode:         safe — Claude prompts before each tool call"
  fi
} >&2

if [[ -t 0 ]]; then
  printf "Continue? [Y/n] " >&2
  read -r reply
  case "$reply" in
    n|N|no|No|NO) echo "claude-cask: aborted" >&2; exit 1 ;;
  esac
fi

# Don't `exec` — we need the cleanup trap (and the post-run hints below)
# to run after docker exits.
docker "${DOCKER_ARGS[@]}"
status=$?

# When --keep-container was set, surface the container id and cleanup
# hints so the user can inspect logs/state and remove the container when
# they're done.
if [[ $KEEP_CONTAINER -eq 1 && -n "$CID_FILE" && -s "$CID_FILE" ]]; then
  cid="$(cat "$CID_FILE")"
  rm -f "$CID_FILE"
  {
    echo
    echo "claude-cask: container kept for post-mortem (id: $cid)"
    echo "  docker logs $cid"
    echo "  docker inspect $cid"
    echo "  docker rm $cid     # when you're done"
  } >&2
fi

exit $status
